{
  "name": "互动操作",
  "description": "点赞、评论、关注",
  "version": "1.0.0",
  "utils": {
    "wait_random": "在 min_seconds 和 max_seconds 之间随机等待，使用 beta 分布模拟人类行为"
  },
  "actions": {
    "点赞": {
      "steps": [
        {
          "action": "click",
          "target": ".like-btn"
        },
        {
          "action": "wait_random",
          "min_seconds": 3,
          "max_seconds": 15
        }
      ]
    },
    "评论": {
      "steps": [
        {
          "action": "click",
          "target": ".comment-btn"
        },
        {
          "action": "wait_for_selector",
          "selector": ".comment-input"
        },
        {
          "action": "fill",
          "target": ".comment-input",
          "value": "{comment_text}"
        },
        {
          "action": "click",
          "target": ".submit-comment"
        },
        {
          "action": "wait_random",
          "min_seconds": 5,
          "max_seconds": 20
        }
      ],
      "required_params": ["comment_text"]
    },
    "关注": {
      "steps": [
        {
          "action": "click",
          "target": ".follow-btn"
        },
        {
          "action": "wait_random",
          "min_seconds": 5,
          "max_seconds": 20
        }
      ]
    }
  },
  "notes": "根据实际页面结构调整选择器；所有等待都使用随机延迟避免被检测"
}
