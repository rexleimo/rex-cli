{
  "skill_name": "热点追踪分析",
  "description": "实时追踪小红书平台热门内容和话题趋势，分析爆款规律",
  "trigger_keywords": ["热点", "趋势", "热门", "分析", "爆款", "追踪"],
  "data_sources": [
    "小红书搜索页热门话题",
    "推荐页高热度笔记",
    "品类榜/热搜榜",
    "同赛道博主内容"
  ],
  "analysis_metrics": [
    "点赞数/收藏数/评论数",
    "话题浏览量增长趋势",
    "内容形式（图文/视频）",
    "发布时间规律"
  ],
  "output_format": {
    "热点话题": [
      {
        "话题": "string",
        "热度": "高/中/低",
        "浏览量": "number",
        "相关笔记数": "number"
      }
    ],
    "爆款规律": [
      "内容类型",
      "标题特点",
      "形式偏好",
      "发布时间"
    ],
    "趋势预测": "未来3-7天可能爆的方向"
  },
  "workflow": [
    {
      "step": 1,
      "action": "搜索热门话题",
      "keywords": "情感、恋爱、大学生"
    },
    {
      "step": 2,
      "action": "分析推荐页高热度笔记",
      "sample_size": "20-30篇"
    },
    {
      "step": 3,
      "action": "提取爆款规律",
      "维度": "类型、标题、形式、发布时间"
    },
    {
      "step": 4,
      "action": "生成趋势报告",
      "format": "热点话题 + 规律总结 + 建议方向"
    }
  ],
  "update_frequency": "每次发布前必做"
}
