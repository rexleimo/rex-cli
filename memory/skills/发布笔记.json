{
  "skill_name": "发布小红书笔记",
  "description": "完整的小红书笔记发布流程，包括配图生成、内容撰写、发布",
  "trigger_keywords": ["发布笔记", "发小红书", "发笔记", "写笔记"],
  "platforms": {
    "xiaohongshu": "creator.xiaohongshu.com",
    "jimeng": "jimeng.jianying.com"
  },
  "primary_image_tool": "baoyu-xhs-images",
  "steps": [
    {
      "step": 1,
      "action": "确定笔记主题和内容",
      "details": [
        "情感恋爱 → 粉色浪漫系",
        "情绪管理 → 暖黄治愈系",
        "人际关系 → 活泼明亮系",
        "大学成长 → 清新自然系"
      ]
    },
    {
      "step": 2,
      "action": "选择配图方式",
      "options": [
        {
          "type": "剧本式多图生成（推荐）",
          "skill": "剧本式多图生成",
          "details": [
            "适用于故事性/漫画类内容",
            "生成4-9张独立画面，按剧情连贯",
            "像条漫/小剧场效果",
            "用户滑动体验更好"
          ]
        },
        {
          "type": "单张配图",
          "skill": "生成小红书配图",
          "details": [
            "适用于干货/教程类内容",
            "1张封面 + 1-2张配图",
            "信息密集型布局"
          ]
        }
      ]
    },
    {
      "step": 3,
      "action": "或者使用即梦AI生成配图（备选）",
      "fallback": true,
      "details": [
        "打开 https://jimeng.jianying.com/ai-tool/image/generate",
        "选择3:4竖版比例",
        "输入对应主题的提示词",
        "生成1张封面 + 1-2张配图",
        "下载保存到 aios/images/ 文件夹"
      ]
    },
    {
      "step": 4,
      "action": "打开小红书创作平台",
      "url": "https://creator.xiaohongshu.com/publish/publish"
    },
    {
      "step": 5,
      "action": "上传图片",
      "details": [
        "点击上传图文",
        "上传封面图和配图"
      ]
    },
    {
      "step": 6,
      "action": "填写标题和正文",
      "details": [
        "标题：吸引眼球，引起共鸣",
        "正文：干货+情感结合",
        "添加话题标签"
      ]
    },
    {
      "step": 7,
      "action": "发布笔记",
      "details": [
        "检查封面预览",
        "点击发布按钮",
        "记录发布结果"
      ]
    }
  ],
  "content_templates": {
    "两性恋爱": {
      "topics": ["#情感", "#恋爱", "#大学生", "#恋爱心理"],
      "style": "温柔、真实、有共鸣"
    },
    "情绪管理": {
      "topics": ["#成长", "#自我提升", "#大学生", "#情绪管理"],
      "style": "温暖、治愈、实用"
    },
    "人际关系": {
      "topics": ["#人际关系", "#宿舍", "#大学", "#相处之道"],
      "style": "真实、接地气、有建议"
    },
    "大学成长": {
      "topics": ["#大学", "#成长", "#大学生", "#校园"],
      "style": "干货、有帮助、鼓励"
    }
  },
  "limits": {
    "daily_posts": 3,
    "daily_interactions": 50,
    "min_interval_seconds": 300
  },
  "notes": [
    "每篇笔记都要有独特的配图，不要重复使用",
    "先确定配图风格，再写内容",
    "每日发布不超过3篇",
    "发布后记录到history文件夹",
    "优先使用baoyu-xhs-images生成高质量图文系列"
  ]
}
