  "video_prompt_template": "用于AI生成视频的提示词结构",
  "elements": [
    "场景描述",
    "人物动作",
    "氛围/色调",
    "时长要求",
    "旁白/字幕风格"
  ],
  "example": {
    "主题": "大学生恋爱日常",
    "prompt": "校园场景，一对情侣在图书馆学习，阳光透过窗户洒在桌上，两人偶尔相视一笑，温馨甜蜜的氛围，马卡龙色调，青春校园风格"
  }
}
