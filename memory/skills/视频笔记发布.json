{
  "skill_name": "视频笔记发布",
  "description": "创建和发布视频类笔记，包含视频生成或上传、配图、标题、话题标签",
  "trigger_keywords": ["发视频", "视频笔记", "短视频", "发布视频"],
  "platform_requirements": {
    "时长": "4小时以内",
    "大小": "最大20GB",
    "格式": "支持常用视频格式，推荐mp4、mov",
    "分辨率": "超过1080P画质更清晰",
    "比例": "推荐3:4竖版或9:16"
  },
  "video_types": {
    "vlog": {
      "description": "日常生活记录",
      "duration": "30s-3min",
      "style": "真实、有趣、有故事性"
    },
    "tutorial": {
      "description": "教程类内容",
      "duration": "1-5min",
      "style": "清晰、干货、有步骤"
    },
    "chat": {
      "description": "对话/访谈类",
      "duration": "1-3min",
      "style": "自然、有情绪价值"
    }
  },
  "workflow": [
    {
      "step": 1,
      "action": "确定视频内容主题",
      "template": "选题规划skill确定主题"
    },
    {
      "step": 2,
      "action": "生成或准备视频素材",
      "options": [
        "使用即梦AI生成视频 (jimeng.jianying.com)",
        "上传本地视频",
        "使用剪映制作"
      ]
    },
    {
      "step": 3,
      "action": "打开小红书创作平台",
      "url": "https://creator.xiaohongshu.com/publish/publish"
    },
    {
      "step": 4,
      "action": "点击上传视频",
      "element": "上传视频按钮"
    },
    {
      "step": 5,
      "action": "填写视频标题",
      "tips": "标题要有吸引力，包含关键词"
    },
    {
      "step": 6,
      "action": "添加话题标签",
      "数量": "3-5个",
      "source": "热门话题.json"
    },
    {
      "step": 7,
      "action": "设置封面",
      "tips": "封面要吸引眼球，可使用视频关键帧或单独制作"
