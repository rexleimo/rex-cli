{
  "name": "publish笔记",
  "description": "发布小红书笔记",
  "version": "1.0.0",
  "steps": [
    {
      "action": "navigate",
      "target": "https://creator.xiaohongshu.com/creator/post"
    },
    {
      "action": "wait_for_selector",
      "selector": ".publish-btn"
    },
    {
      "action": "fill",
      "target": ".title-input",
      "value": "{title}"
    },
    {
      "action": "fill",
      "target": ".content-editor",
      "value": "{content}"
    },
    {
      "action": "click",
      "target": ".publish-btn"
    },
    {
      "action": "wait_for_navigation"
    }
  ],
  "required_params": ["title", "content"],
  "notes": "可根据实际页面结构调整选择器"
}
