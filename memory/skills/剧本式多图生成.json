{
  "skill_name": "剧本式多图生成",
  "description": "以剧本/分镜方式生成系列独立图片，用于小红书笔记多图上传。不同于拼接图，每张图都是完整画面，按剧情连贯排列，形成漫画/条漫效果。",
  "trigger_keywords": ["剧本", "分镜", "漫画", "多图", "连载", "故事", "小剧场", "条漫", "系列图", "连续画面"],
  "适用场景": [
    "恋爱日常小剧场",
    "宿舍/社交故事",
    "情绪变化记录",
    "教程步骤图",
    "对比展示",
    "日常vlog风格"
  ],
  "工作流程": {
    "step1_主题确定": {
      "action": "确定笔记主题和核心故事",
      "问题": [
        "这个笔记讲什么故事？",
        "目标用户是谁？",
        "想传递什么情绪/价值？"
      ],
      "示例主题": [
        "男朋友的直男操作",
        "宿舍夜聊",
        "追crush的日常",
        "考试周心理变化"
      ]
    },
    "step2_剧本写作": {
      "action": "编写分镜脚本，规划每张图的内容",
      "格式": {
        "图序": "第N张图",
        "画面": "具体描述看到了什么",
        "文字": "图中要配的文字（可选）",
        "情绪": "这张图传递什么情绪"
      },
      "数量建议": "4-9张最佳（小红书最多18张）",
      "技巧": [
        "起承转合：开头→发展→高潮→结尾",
        "每张图有独立情绪",
        "留悬念吸引滑到下一张",
        "最后一张可以有反转或互动引导"
      ]
    },
    "step3_风格确定": {
      "action": "根据主题确定整体视觉风格",
      "风格匹配": {
        "情感恋爱": {
          "style": "cute",
          "mood": "甜蜜、温馨、反差萌",
          "配色": "粉色浪漫系"
        },
        "人际关系": {
          "style": "fresh",
          "mood": "真实、接地气、有趣",
          "配色": "活泼明亮系"
        },
        "情绪管理": {
          "style": "warm",
          "mood": "治愈、温暖、放松",
          "配色": "暖黄治愈系"
        },
        "大学成长": {
          "style": "notion",
          "mood": "干货、有帮助、鼓励",
          "配色": "清新自然系"
        },
        "搞笑日常": {
          "style": "pop",
          "mood": "活泼、有梗、幽默",
          "配色": "活泼明亮系"
        }
      }
    },
    "step4_图片生成": {
      "action": "使用AI工具逐张生成图片",
      "primary_tool": "baoyu-xhs-images",
      "fallback": "即梦AI",
      "流程": [
        "1. 根据剧本，为每张图写AI提示词",
        "2. 保持角色/风格一致性",
        "3. 逐张生成并保存",
        "4. 检查连贯性"
      ],
      "提示词要点": [
        "描述具体画面内容",
        "指定情绪氛围",
        "说明构图（近景/远景/特写）",
        "保持配色一致",
        "避免文字（让AI生成纯画面）"
      ],
      "比例": "3:4（小红书竖版最佳）"
    },
    "step5_上传发布": {
      "action": "将生成的系列图上传到小红书",
      "顺序": "按剧本顺序排列",
      "技巧": [
        "封面图放在第一张",
        "剧情连贯性",
        "最后一张可以加引导评论"
      ]
    }
  },
  "剧本模板": {
    "恋爱小剧场_模板": {
      "主题": "和crush的日常",
      "风格": "cute/甜酷",
      "人物": "女主+crush（可用Q版形象）",
      "分镜": [
        {"序号": 1, "画面": "女主独自在教室，看着窗外", "情绪": "无聊/期待", "文字": "今天又是平凡的一天..."},
        {"序号": 2, "画面": "手机震动，收到消息", "情绪": "紧张/期待", "文字": "手机响了！"},
        {"序号": 3, "画面": "打开手机，是crush发来的'在干嘛'", "情绪": "窃喜", "文字": "是他！"},
        {"序号": 4, "画面": "女主故意等几分钟再回复", "情绪": "傲娇", "文字": "哼，要等等再回"},
        {"序号": 5, "画面": "crush打电话来", "情绪": "惊喜", "文字": "居然打电话了！"},
        {"序号": 6, "画面": "两人约好晚上见面", "情绪": "甜蜜", "文字": "今晚见～"}
      ]
    },
    "宿舍故事_模板": {
      "主题": "宿舍夜聊",
      "风格": "fresh/清新",
      "人物": "4个宿舍姐妹",
      "分镜": [
        {"序号": 1, "画面": "熄灯后的宿舍", "情绪": "神秘", "文字": "深夜11点..."},
        {"序号": 2, "画面": "某室友突然说'我有一个瓜'", "情绪": "好奇", "文字": "都别睡！"},
        {"序号": 3, "画面": "其他室友搬小板凳围观", "情绪": "兴奋", "文字": "快说快说！"},
        {"序号": 4, "画面": "讲述中...", "情绪": "紧张", "文字": "然后你们猜怎么着？"},
        {"序号": 5, "画面": "所有人震惊表情", "情绪": "惊讶", "文字": "什么？？？"},
        {"序号": 6, "画面": "第二天全员迟到", "情绪": "无奈", "文字": "熬夜一时爽"}
      ]
    }
  },
  "提示词示例": {
    "恋爱场景1_教室": "教室内景，傍晚时分，一个女生坐在窗边位置，阳光透过窗户洒在桌上，女生看向窗外若有所思，简约清新风格，柔和光线，暖色调氛围，无文字",
    "恋爱场景2_手机": "女生宿舍，一个女生躺在床上举着手机，手机屏幕发亮显示收到新消息，女孩表情惊喜期待，温馨室内场景，暖黄灯光，甜美可爱风格，无文字",
    "恋爱场景3_通话": "校园夜景，女生走在路上接着电话，脸上洋溢着甜蜜的笑容，手机屏幕显示通话中，背景是校园路灯，浪漫氛围，甜蜜风格，无文字"
  },
  "输出要求": {
    "图片保存位置": "aios/images/",
    "命名规范": "{主题}_{序号}_{日期}.png",
    "示例": "恋爱剧场_01_20260301.png"
  },
  "注意事项": [
    "每张图必须是独立完整画面，不是拼接",
    "按剧本顺序生成，保持连贯性",
    "风格和角色形象要一致",
    "控制单次生成数量（4-9张为宜）",
    "生成后检查是否有不需要的文字",
    "可先用1张测试风格，再批量生成"
  ]
}
