{
  "skill_name": "内容选题规划",
  "description": "根据热点话题、用户画像和账号定位，自动生成内容选题方案",
  "trigger_keywords": ["选题", "写什么", "内容规划", "话题推荐", "写什么内容"],
  "analysis_inputs": [
    "当前热门话题",
    "目标用户兴趣",
    "账号定位/风格",
    "历史爆款内容分析"
  ],
  "output_format": {
    "选题列表": [
      {
        "标题": "string",
        "类型": "恋爱日常/态度宣言/干货分享/穿搭分享",
        "话题标签": ["array"],
        "爆款潜力": "高/中/低",
        "创作难度": "简单/中等/复杂"
      }
    ]
  },
  "generation_steps": [
    {
      "step": 1,
      "action": "获取当前热门话题",
      "source": "热门话题.json + 实时搜索"
    },
    {
      "step": 2,
      "action": "分析目标用户兴趣",
      "source": "爆款内容分析.json 用户画像"
    },
    {
      "step": 3,
      "action": "结合账号定位生成选题",
      "template": "热门话题 + 账号风格 = 个性化选题"
    },
    {
      "step": 4,
      "action": "输出选题方案",
      "format": "包含标题、类型、标签、潜力评估"
    }
  ],
  "example": {
    "账号定位": "知心学姐型 - 情感恋爱类",
    "生成选题": [
      {
        "标题": "和男朋友同居后才发现的10件小事",
        "类型": "恋爱日常",
        "标签": ["#情侣日常", "#甜甜的恋爱", "#同居生活"],
        "爆款潜力": "高",
        "创作难度": "简单"
      }
    ]
  }
}
