{
  "name": "数据分析",
  "description": "获取账号和笔记数据",
  "version": "1.0.0",
  "metrics": {
    "账号数据": ["粉丝数", "点赞数", "收藏数", "评论数", "分享数"],
    "笔记数据": ["浏览量", "点赞数", "收藏数", "评论数", "转化率"]
  },
  "steps": [
    {
      "action": "navigate",
      "target": "https://creator.xiaohongshu.com/"
    },
    {
      "action": "wait_for_selector",
      "selector": ".data-overview"
    },
    {
      "action": "evaluate_script",
      "script": "return document.querySelector('.data-overview').innerText"
    }
  ],
  "notes": "可根据实际分析需求扩展"
}
